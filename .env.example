# Copy this file to .env and fill in your real values. Never commit .env to git.
# When deploying (e.g. to Railway), set these as environment variables in the
# host's dashboard instead - .env files aren't used in most cloud deployments.
#
# Get both from https://id.getharvest.com/developers - create a Personal Access Token
# there; it will show you the Account ID at the same time.

HARVEST_ACCOUNT_ID=your_account_id_here
HARVEST_ACCESS_TOKEN=your_personal_access_token_here
